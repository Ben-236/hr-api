generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id   String @id @default(uuid())
  name String

  annualLeaveBalance Int

  leaveRequests LeaveRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeaveRequest {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  leaveType LeaveType

  startDate DateTime
  endDate   DateTime

  daysRequested Int

  reason String?

  status LeaveStatus @default(PENDING)

  approvedBy String?
  approvedAt DateTime?

  rejectionComment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
}

enum LeaveType {
  ANNUAL
  SICK
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}